# Firebase Configuration
VITE_FIREBASE_PROJECT_ID=sq-timetracker
VITE_FIRESTORE_DATABASE_ID=(default)

# Feature Flags (DEV/STAGING ONLY)
# VITE_DEV_AUTH_BYPASS: Temporary development switch for login bypass.
# true  -> skip OAuth login (DEV ONLY, security risk!)
# false -> normal OAuth login flow (default)
VITE_DEV_AUTH_BYPASS=false

# VITE_AUDIT_LOGGING: Enable structured logging of all data changes
# true  -> log all create/update/delete operations
# false -> basic logging only (default)
VITE_AUDIT_LOGGING=false

# Build environment (automatically set by build tools)
# values: development, staging, production
MODE=development
